# Database
DATABASE_URL="postgresql://user:password@localhost:5432/macroplate"
# OR for local dev:
# DATABASE_URL="file:./dev.db"

# JWT
ACCESS_TOKEN_SECRET="macroplate-access-secret-change-in-prod-min-32-chars"
REFRESH_TOKEN_SECRET="macroplate-refresh-secret-change-in-prod-min-32-chars"

# App
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# AWS S3
AWS_ACCESS_KEY_ID="your-key"
AWS_SECRET_ACCESS_KEY="your-secret"
AWS_S3_BUCKET="macroplate-images"
AWS_REGION="us-east-1"

# SendGrid
SENDGRID_API_KEY="SG...."
FROM_EMAIL="noreply@macroplate.com"
